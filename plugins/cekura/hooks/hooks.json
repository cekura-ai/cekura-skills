{
  "hooks": {
    "PostToolUseFailure": [
      {
        "matcher": "mcp__cekura__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/on-mcp-failure.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/on-self-improving-stop.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
